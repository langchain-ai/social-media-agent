{
  "name": "example-graph",
  "version": "0.0.1",
  "description": "A starter template for creating a LangGraph workflow.",
  "packageManager": "yarn@1.22.22",
  "main": "my_app/graph.ts",
  "author": "Your Name",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "yarn langgraph:in_mem:up",
    "build": "tsc",
    "clean": "rm -rf dist",
    "test": "cross-env TZ=America/Los_Angeles node --experimental-vm-modules node_modules/jest/bin/jest.js --testPathPatterns=\\.test\\.ts$ --testPathIgnorePatterns=\\.int\\.test\\.ts$",
    "test:int": "cross-env TZ=America/Los_Angeles node --experimental-vm-modules node_modules/jest/bin/jest.js --testPathPatterns=\\.int\\.test\\.ts$",
    "test:single": "cross-env TZ=America/Los_Angeles NODE_OPTIONS=--experimental-vm-modules yarn run jest --config jest.config.js --testTimeout 100000",
    "format": "prettier --write .",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format:check": "prettier --check .",
    "lint:langgraph-json": "node scripts/checkLanggraphPaths.js",
    "lint:all": "yarn lint && yarn lint:langgraph-json",
    "test:all": "yarn test && yarn test:int && yarn lint:langgraph",
    "start:auth": "yarn tsx src/clients/auth-server.ts",
    "generate_post": "yarn tsx scripts/generate-post.ts",
    "cron:create": "yarn tsx scripts/crons/create-cron.ts",
    "cron:delete": "yarn tsx scripts/crons/delete-cron.ts",
    "cron:list": "yarn tsx scripts/crons/list-crons.ts",
    "graph:backfill": "yarn tsx scripts/backfill.ts",
    "get:scheduled_runs": "yarn tsx scripts/get-scheduled-runs.ts",
    "get:used_links": "yarn tsx scripts/get-all-used-links.ts",
    "graph:delete:run_thread": "yarn tsx scripts/delete-run-thread.ts",
    "langgraph:up": "langgraph up --watch --port 54367",
    "langgraph:in_mem:up": "npx @langchain/langgraph-cli@latest dev --port 54367"
  },
  "dependencies": {
    "@arcadeai/arcadejs": "^2.4.1",
    "@google/genai": "^2.8.0",
    "@googleapis/youtube": "^33.0.0",
    "@langchain/anthropic": "^1.4.1",
    "@langchain/community": "^1.1.29",
    "@langchain/core": "^1.1.49",
    "@langchain/google-vertexai-web": "^2.1.31",
    "@langchain/langgraph": "^1.4.2",
    "@langchain/langgraph-sdk": "1.9.22",
    "@langchain/openai": "^1.4.7",
    "@mendable/firecrawl-js": "4.25.4",
    "@octokit/rest": "^22.0.1",
    "@slack/web-api": "^7.17.0",
    "@supabase/supabase-js": "^2.108.1",
    "@types/snoowrap": "^1.19.0",
    "cheerio": "^1.0.0",
    "date-fns": "^4.4.0",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-session": "^1.18.1",
    "file-type": "^22.0.1",
    "google-auth-library": "^10.7.0",
    "langsmith": "^0.7.7",
    "moment": "^2.30.1",
    "passport": "^0.7.0",
    "passport-twitter": "^1.0.4",
    "playwright": "^1.60.0",
    "sharp": "^0.35.1",
    "snoowrap": "^1.23.0",
    "twitter-api-v2": "^1.18.2",
    "uuid": "^14.0.1",
    "xml2js": "^0.6.2",
    "zod": "^4.4.3"
  },
  "resolutions": {
    "axios": "^1.16.1",
    "jws": "^4.0.1",
    "form-data": "^4.0.4",
    "qs": "^6.14.1",
    "lodash": "^4.18.1",
    "brace-expansion": "^2.0.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@jest/globals": "^30.4.1",
    "@tsconfig/recommended": "^1.0.7",
    "@types/express": "^5.0.0",
    "@types/express-session": "^1.19.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.0.0",
    "@types/passport": "^1.0.17",
    "@types/passport-twitter": "^1.0.40",
    "@types/xml2js": "^0.4.14",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "cross-env": "^10.1.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.27.5",
    "eslint-plugin-no-instanceof": "^1.0.1",
    "eslint-plugin-prettier": "^5.5.6",
    "jest": "^30.4.2",
    "prettier": "^3.8.4",
    "timezone-mock": "^1.3.6",
    "ts-jest": "^29.4.11",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
